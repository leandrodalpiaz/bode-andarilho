# =====================================================================
# BODE ANDARILHO - ARQUIVO DE CONFIGURAÇÃO DE EXEMPLO
# =====================================================================
# Instruções:
# 1. Copie este arquivo e renomeie para ".env" na raiz do projeto.
# 2. Preencha as credenciais reais abaixo.
# 3. O arquivo ".env" nunca deve ser enviado ao repositório Git.
# =====================================================================

# ---------------------------------------------------------------------
# ⚙️ CONFIGURAÇÕES DO SUPABASE (OBRIGATÓRIO)
# ---------------------------------------------------------------------
# URL do seu projeto Supabase (ex: https://xyzabc.supabase.co)
SUPABASE_URL=https://seu-projeto.supabase.co
# Chave pública de API (anon key)
SUPABASE_KEY=sua-chave-anonima-do-supabase

# ---------------------------------------------------------------------
# 🤖 CONFIGURAÇÕES DO TELEGRAM (OBRIGATÓRIO)
# ---------------------------------------------------------------------
# Token gerado pelo @BotFather para o seu bot
TELEGRAM_TOKEN=123456789:ABCdefGHIjklmNOPQrStuvWxYz-abcdefgh
# ID numérico do grupo principal do Telegram (com o sinal de menos se aplicável)
GRUPO_PRINCIPAL_ID=-1000000000000

# ---------------------------------------------------------------------
# 🌐 CONFIGURAÇÕES DO SERVIDOR E WEBHOOK
# ---------------------------------------------------------------------
# URL pública onde o servidor está acessível (ex: Render, Railway, Ngrok)
RENDER_EXTERNAL_URL=https://seu-app-bode.onrender.com
# Porta local em que o servidor Starlette/Uvicorn irá escutar
PORT=10000
# Caminho relativo do endpoint do webhook
WEBHOOK_PATH=/telegram/webhook
# Segredo para validar requisições genuínas do Telegram (opcional mas recomendado)
TELEGRAM_WEBHOOK_SECRET=seu-segredo-anti-fraude-token
# Descartar atualizações pendentes na inicialização do bot (true/false)
DROP_PENDING_UPDATES_ON_BOOT=false

# ---------------------------------------------------------------------
# 👑 SEGURANÇA E PERMISSÕES
# ---------------------------------------------------------------------
# Seu ID do Telegram para bypass automático de permissões nível 3 (Admin Master)
ADMIN_TELEGRAM_ID=000000000
